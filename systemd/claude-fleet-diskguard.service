# claude-fleet disk-pressure watcher — Linux systemd user unit (parity with
# launchd com.claude-fleet.diskguard). Oneshot driven by the .timer. On low disk
# it captures a forensic incident + notifies; the --gate mode (called by fleet-up
# and fleet-restore) is the paired circuit-breaker. See bin/fleet-diskguard.sh.
[Unit]
Description=claude-fleet disk-pressure watcher (forensics + circuit-breaker)

[Service]
Type=oneshot
ExecStart=/bin/bash __HOME__/.claude/fleet/bin/fleet-diskguard.sh --watch
Environment=HOME=__HOME__
Environment=LANG=en_US.UTF-8
Environment=PATH=__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
StandardOutput=null
StandardError=append:__HOME__/.claude/fleet/logs/diskguard.systemd.log
