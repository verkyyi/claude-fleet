# claude-fleet crash/boot restore watcher — Linux systemd user unit (parity with
# launchd com.claude-fleet.restore). Oneshot driven by claude-fleet-restore.timer.
# `fleet-restore.sh --if-down` restores the fleet ONLY when the tmux server is
# absent AND auto-restore is armed (`fleet-restore.sh --arm`) — a no-op otherwise.
[Unit]
Description=claude-fleet crash/boot restore watcher

[Service]
Type=oneshot
ExecStart=/bin/bash __HOME__/.claude/fleet/bin/fleet-restore.sh --if-down
Environment=HOME=__HOME__
Environment=LANG=en_US.UTF-8
Environment=PATH=__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
StandardOutput=null
StandardError=append:__HOME__/.claude/fleet/logs/restore.systemd.log
