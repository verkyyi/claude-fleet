# claude-fleet classifier — Linux systemd user unit (parity with launchd
# com.claude-fleet.classify). Oneshot driven by claude-fleet-classify.timer.
# Optional: spends small, change-gated LLM tokens. Needs `claude` on PATH.
[Unit]
Description=claude-fleet session classifier (corrects state, detects looping)

[Service]
Type=oneshot
ExecStart=/bin/bash __HOME__/.claude/fleet/bin/classify-sessions.sh
Environment=HOME=__HOME__
Environment=LANG=en_US.UTF-8
Environment=PATH=__HOME__/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
StandardOutput=null
StandardError=append:__HOME__/.claude/fleet/logs/classify.systemd.log
