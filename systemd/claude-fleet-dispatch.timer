# Fires claude-fleet-dispatch.service. Parity with the launchd plist:
# StartInterval=60 + RunAtLoad=true. The dispatcher is OFF until a fleet opts in
# with FLEET_AUTOFILL=1 AND an issue carries the `autofill` label (issue #421), so
# the timer is safe to enable globally. Install: `systemctl --user enable --now
# claude-fleet-dispatch.timer`.
[Unit]
Description=claude-fleet autofill dispatcher timer (every 60s)

[Timer]
OnStartupSec=20
OnUnitActiveSec=60
AccuracySec=10s

[Install]
WantedBy=timers.target
