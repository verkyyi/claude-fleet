# claude-fleet configuration — copy to <install-dir>/fleet.conf and edit.
# Sourced by the fleet scripts (plain shell; keep it assignments-only).
#
# TAG LINES (the "# @label=… @group=… @tier=… @scope=… @edit=… @unit=…" line
# directly above each key) are the DECLARATIVE source of truth for the prefix+c
# config modal (issue #89). One reviewable file drives the whole UI — there is
# no hardcoded key list in the scripts. Each key carries three independent
# attributes:
#   @scope  where it may be set:  identity (view-only) · global (writes this
#           fleet.conf, no per-fleet override) · fleet (per-fleet overlay on top
#           of the global default, via the modal's g/f write-scope toggle).
#   @tier   modal visibility:     common (default view) · advanced (collapsed).
#   @edit   editor + validation:  no · bool · int · enum · path · str · regex.
# @label is the friendly name shown in the modal; @group buckets rows into
# sections; @unit is an optional display suffix. Adding a key here (with a tag
# line) makes it appear in the modal automatically — nothing to keep in sync.

# ── Identity ────────────────────────────────────────────────────────────────
# These pin WHICH repo/checkout this fleet is. They are view-only in the modal
# (@edit=no): change them by editing fleet.conf and re-provisioning, not live.

# The GitHub repo whose issues are your backlog (owner/name). Required for the
# backlog panel, issue-bound sessions, and PR/CI cells.
# @label=GitHub repo @group=identity @tier=common @scope=identity @edit=no
FLEET_REPO="you/your-repo"

# Main checkout of that repo — issue worktrees are created as SIBLINGS of this
# directory (your-repo-issue-123 next to your-repo).
# @label=Base checkout path @group=identity @tier=common @scope=identity @edit=no
FLEET_MAIN="$HOME/projects/your-repo"

# Branch new work forks from (and merged-ness is measured against).
# @label=Base branch (locked) @group=identity @tier=common @scope=identity @edit=no
FLEET_BASE_BRANCH="main"

# Directory holding the per-fleet config overlays (<session>.conf), which the
# modal writes when its scope is set to per-fleet. Defaults to
# $HOME/.config/claude-fleet; override only if you relocate the fleet state dir.
# @label=Per-fleet config dir @group=identity @tier=advanced @scope=identity @edit=no
#FLEET_CONF_DIR="$HOME/.config/claude-fleet"

# Branches the worktree janitor must never touch (extended regex).
# @label=Protected-branch pattern @group=janitor @tier=advanced @scope=fleet @edit=regex
FLEET_PROTECTED_RE="^(master|main|develop|test)$"

# Context window used for the dash's ctx% column (tokens). 200000 for standard
# plans; 1000000 if your sessions run 1M-context models.
# @label=Context window size @group=cache @tier=advanced @scope=fleet @edit=int @unit=tokens
FLEET_CTX_WINDOW=200000

# Model every spawned fleet session launches with (passed as `claude --model`).
# Default: opus — so a new window never silently falls back to sonnet. Set empty
# to defer to your own `claude` default; an explicit --model in the spawn still
# wins. Honored globally here or per-fleet in $FLEET_CONF_DIR/<session>.conf.
# @label=Worker model @group=spawn @tier=common @scope=fleet @edit=enum
#FLEET_MODEL="opus"

# Model the session's SUBAGENTS (Task/Agent spawns) run on, exported as
# CLAUDE_CODE_SUBAGENT_MODEL — the only global switch for subagent models (there
# is no settings.json key). Overrides even the pinned built-ins (claude-code-guide
# runs haiku, statusline-setup runs sonnet by default). Defaults to FLEET_MODEL
# (so subagents follow the session onto opus). Set to "inherit" to let each
# subagent resolve normally, or empty to leave the env var untouched.
# @label=Subagent model @group=spawn @tier=advanced @scope=fleet @edit=enum
#FLEET_SUBAGENT_MODEL="opus"

# SYSTEM-WIDE ceiling on how many Claude working sessions may run at once across
# ALL fleets on this machine. Every spawn path — the new-session box and the
# backlog's Enter — refuses once this many are live (panels — the dash/plan/
# backlog windows — don't count). Default 8; set to 0 to disable entirely.
# @label=Max sessions — all fleets @group=caps @tier=common @scope=global @edit=int @unit=sessions
FLEET_GLOBAL_MAX_SESSIONS=8

# PER-FLEET ceiling on concurrent Claude working sessions in THIS fleet, enforced
# alongside the global cap by every spawn path (a spawn needs BOTH caps to have
# headroom). Default 0 = unlimited (only the global cap applies) — set it to give
# one repo its own slice of the global budget. Best set per-fleet in
# $FLEET_CONF_DIR/<session>.conf; a value here applies to every fleet.
# @label=Max sessions — this fleet @group=caps @tier=common @scope=fleet @edit=int @unit=sessions
#FLEET_MAX_SESSIONS=0

# --- Issue-bridge: issue comments → the bound worker's next turn (issue #132) ---
# OFF by default. When enabled for a fleet, the issue-bridge daemon
# (com.claude-fleet.issue-bridge, ~15s poll — or a webhook, see docs/ISSUE-BRIDGE.md)
# relays a trusted comment on a bound issue INTO that worker as its next turn.
# The issue thread becomes the single durable channel for driving a worker
# (steward→worker, external-collaborator→worker), replacing flaky send-keys.
#
# SECURITY: a relayed comment becomes autonomous tool-use in a bypass-permissions
# worker — treat it as remote code execution. The author_association gate below is
# the headline control; un-gated relay on a PUBLIC repo is unsafe. Loop-safety: the
# bridge relays every comment from a trusted author UNLESS it carries the marker
# `<!-- fleet:no-relay -->` — fleet-internal comments (worker progress, steward
# record) MUST be posted via bin/fleet-comment.sh (which stamps the marker), so
# nothing the fleet writes loops back in. See docs/ISSUE-BRIDGE.md.
# @label=Relay issue comments to worker @group=bridge @tier=common @scope=fleet @edit=bool
#FLEET_ISSUE_BRIDGE=0
# Trusted author_association floor (space-separated, verbatim GitHub values). Only
# comments whose author is in this set are relayed; NONE/CONTRIBUTOR are refused.
# Default: the three trusted tiers. Widen it ONLY if you understand the RCE risk.
# @label=Bridge: trusted associations @group=bridge @tier=advanced @scope=fleet @edit=str
#FLEET_ISSUE_BRIDGE_ASSOC_FLOOR="OWNER MEMBER COLLABORATOR"
# Webhook HMAC secret (the `gh webhook forward` / cloudflared shared secret). Used
# by `--deliver` to validate that only GitHub triggered a delivery — MANDATORY for
# the webhook ingress (the poll ingress needs no secret). Keep it out of the conf
# in a real deploy; the daemon reads it from the environment. See docs.
# @label=Bridge: webhook HMAC secret @group=bridge @tier=advanced @scope=global @edit=str
#FLEET_ISSUE_BRIDGE_SECRET=""
# Revive a DORMANT issue: when a trusted comment lands on an OPEN issue whose
# worker window is gone, re-spawn the worker (its /fleet-claim re-reads the issue,
# comment and all). OFF by default — turn on once you trust the gate. A closed/
# landed issue is left alone (resume via #130 is a follow-up).
# @label=Bridge: revive dormant issues @group=bridge @tier=advanced @scope=fleet @edit=bool
#FLEET_ISSUE_BRIDGE_REVIVE=0
# Max CONSECUTIVE typing-defers before a relay is delivered anyway (issue #195). The
# bridge DEFERS a relay while the target's ❯ input row holds un-submitted text (so it
# never prepends onto a human's half-typed line, issue #191). That defer is otherwise
# UNBOUNDED: a row that reads non-empty persistently (a stuck render, a future TUI
# placeholder, a capture-pane quirk) would wedge the channel forever — for the
# @steward control channel that silently drops operator messages AND watcher wakes.
# After this many consecutive defers of the SAME comment, the bridge delivers anyway
# and logs a WARNING; the counter resets the moment the input clears, so a real
# partial is never clobbered. TRADE-OFF: keep it GENEROUS enough that a human pausing
# mid-type for a few minutes is respected, small enough that a bad read can't wedge.
# Default 20 ≈ 5 min at the 15s poll. Per-comment, persisted in the bridge state dir.
# @label=Bridge: max typing-defers @group=bridge @tier=advanced @scope=fleet @edit=int @unit=ticks
#FLEET_BRIDGE_MAX_TYPING_DEFERS=20

# --- Steward control issue: relay its comments INTO the steward (issue #146) -----
# The steward lives in the 'plan' hub (a pane with NO @issue), so the issue-bridge
# has no route to it by default. Bind a long-lived control/inbox issue here and the
# bridge relays trusted comments on it INTO the @steward pane as its next turn — the
# steward becomes a bridge endpoint like a worker, giving you (a) an async
# operator↔steward channel (comment from anywhere → the steward takes a turn), (b) an
# event sink for the fleet watcher, and (c) a durable audit log of wake-events. Every
# bridge gate still applies (author_association floor, the <!-- fleet:no-relay -->
# marker, idle-gate on the hub's @claude_state, dedup) — so the steward's OWN notes
# (posted via bin/fleet-comment.sh, which stamps the marker) never loop back into it.
# Create ONE non-closing issue per fleet (e.g. titled "🛰 steward · <fleet>") and
# record its number here. It is a DEDICATED bridge endpoint, never a worker task —
# label it `steward-control` (a control label the spawn-eligibility filters exclude
# so a worker is never spawned on it). Requires FLEET_ISSUE_BRIDGE=1; empty ⇒ no steward
# route (worker relay unchanged). See docs/ISSUE-BRIDGE.md.
# @label=Steward control issue @group=bridge @tier=common @scope=fleet @edit=int
#FLEET_STEWARD_ISSUE=

# --- Cleanup daemon (bin/fleet-cleanup-daemon.sh, com.claude-fleet.cleanup) ------
# ON by default. THE FLEET NEVER MERGES — /fleet-ship arms GitHub auto-merge and
# GitHub (or a human on the web, or a collaborator) does the merge; the cleanup
# daemon (~60s) is what reaps the leftover worktree/window/branch and records the
# resume ledger once a PR is final (MERGED or CLOSED-unmerged). It merges NOTHING
# and relaxes NO approval gate, so it is safe to leave on for every fleet. Detection
# is cache + local (the prmap pr-refresh already writes + a local git/tmux check —
# ZERO extra gh); single-writer per repo + disk-gated. Set to 0 to opt a fleet OUT
# (the worktree-autoclean janitor still backstops merged worktrees). See docs/CLEANUP.md.
# @label=Cleanup daemon (reap after merges) @group=bridge @tier=common @scope=fleet @edit=bool
#FLEET_CLEANUP=1
# Max PRs reaped per fleet per tick (a stampede guard; the ~60s interval is the
# cooldown). Default 4.
# @label=Cleanup batch size @group=bridge @tier=advanced @scope=fleet @edit=int @unit=per tick
#FLEET_CLEANUP_MAX_PER_TICK=4

# --- Fleet watcher: zero-token event-driven steward wake (issue #147) ------------
# OFF by default. When enabled for a fleet, the watch daemon (bin/fleet-watch.sh,
# com.claude-fleet.watch, ~45s) sleeps on the fleet and wakes the STEWARD only on a
# decision-worthy EDGE — a PR going green (`/land <n>?`), a worker opening a PR, a
# worker stuck (looping), the needs-attention count rising, a prod-alert issue
# appearing, or a free slot with eligible backlog. It replaces the steward
# hand-running PR-green pollers.
#
# ZERO-TOKEN: every tick reads only the state the collector + pr-refresh already
# maintain (@claude_state / @prci / @issue, prmap, issues_<slug> + labels_<slug>,
# session counts) — no LLM, no per-tick gh reads. It is edge-triggered + deduped
# (wakes on transitions, not levels; first run seeds silently, no backfill flood).
#
# COST: the watcher itself spends no tokens, but each wake makes the STEWARD take an
# LLM turn — so, like the issue-bridge, it is opt-in per fleet. DELIVERY is the
# steward control issue: the watcher posts the wake to FLEET_STEWARD_ISSUE and the
# issue-bridge relays it into the @steward pane. So it REQUIRES FLEET_STEWARD_ISSUE
# set and, in practice, FLEET_ISSUE_BRIDGE=1. See docs/WATCH.md.
# @label=Watch fleet, wake steward on edges @group=bridge @tier=common @scope=fleet @edit=bool
#FLEET_WATCH=0


# Seconds the backlog panel's issue preview (⌃p) caches each issue's detail
# before re-fetching from gh. Lower = fresher body/comments, more API chatter.
# GLOBAL: read by the preview tool from the global env — a per-fleet override
# would be a silent no-op, so this is machine-wide.
# @label=Issue cache lifetime @group=cache @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_ISSUE_TTL=180

# Seconds the collector caches gh fetches (open issues + the repo-wide PR map)
# before re-fetching. Lower = fresher backlog/PR data, more gh API chatter.
# GLOBAL: the collector is ONE daemon serving every fleet and sets this once —
# it is not per-fleet overridable.
# @label=GitHub cache lifetime @group=cache @tier=common @scope=global @edit=int @unit=sec
#FLEET_GH_TTL=90

# PR-status refresh cadence (bin/tmux-pr-refresh.sh, com.claude-fleet.pr-refresh).
# PR/CI state (the dash PR cell + the status-bar @prci glyph) is refreshed by its
# OWN fast daemon, decoupled from the 60s collector, so "CI went green" / "PR
# merged" surfaces within ~this many seconds — which is when the steward is
# watching to /land. Default 15. This value gates the script's own gh-fetch
# dedup; the DAEMON fire cadence is set in the launchd plist (StartInterval) /
# systemd timer (OnUnitActiveSec) — keep all three in step if you change it.
# GLOBAL: one daemon serves every fleet and its cadence is tied to the plist —
# not per-fleet overridable.
# @label=PR status refresh @group=cache @tier=common @scope=global @edit=int @unit=sec
#FLEET_PR_REFRESH_INTERVAL=15

# Stuck-working demotion (bin/tmux-spinner.sh). A window whose Stop hook was
# missed (crash/race/a turn that didn't emit Stop) stays pinned at
# @claude_state=working forever — the classifier backstop skips working windows.
# The spinner catches it marker-agnostically: a live Claude session repaints its
# pane at least once/second (the elapsed-time counter ticks) so tmux's
# window_activity stays fresh, while a stopped session's pane freezes. A working
# window idle (window_activity stale) longer than this many seconds is demoted to
# done and reclassified. Conservative by design — a live worker never exceeds ~1s
# of activity age (validated), so 120 is a ~120× margin; bias is toward leaving a
# stuck window a tick longer, never toward demoting a busy one. Set to 0 to
# disable. GLOBAL: one spinner daemon serves every fleet.
# @label=Demote stuck-working after @group=status @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_STUCK_WORKING_SECS=120

# Optional: a docker container name to show as ●/○ in the status bar right side.
# GLOBAL: the status bar (bin/tmux-status.sh) reads this from the global env only
# — a per-fleet override would be a silent no-op — so it is machine-wide (like the
# FLEET_DISK_* thresholds the same status bar renders).
# @label=Status-bar container @group=status @tier=advanced @scope=global @edit=str
#FLEET_STATUS_CONTAINER="claude-dev"

# Subscription-limit coloring of the footer usage stat (issue #239). The
# official weekly/N-hour limit % (scraped into the ratelimit cache while fresh)
# is NOT printed as its own footer text — that was noise. Instead the existing
# 5h/7d usage stat CHANGES COLOR: indigo = ok, yellow at/above WARN%, red at/
# above CRIT%. The full detail (which limit, reset time, which account) lives in
# the usage popup — click the stat or press prefix+u. Thresholds (percent of the
# official limit); defaults shown.
# @label=Usage warn % @group=status @tier=advanced @scope=global @edit=int @unit=%
#FLEET_USAGE_WARN_PCT=75
# @label=Usage crit % @group=status @tier=advanced @scope=global @edit=int @unit=%
#FLEET_USAGE_CRIT_PCT=90
# Staleness window for the scraped official limit % (seconds; default 21600 =
# 6h). Past this the color falls back to indigo and the popup drops the line — a
# stale limit % is worse than none. Shared with the collector's scrape.
# @label=Ratelimit staleness @group=status @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_RATELIMIT_TTL=21600

# Optional: the command each fleet's steward pane runs (the bottom pane of the
# always-on 'plan' hub). Unset → the built-in default (adopt ~/.claude/steward.md
# as an on-demand steward scoped to this fleet's repo, resuming the newest
# handoff if one exists). Set it to drive your own steward, or to a plain shell
# to opt out of the auto-driven one.
# Honored globally here or per-fleet in $FLEET_CONF_DIR/<session>.conf.
# @label=Steward launch command @group=steward @tier=advanced @scope=fleet @edit=str
#FLEET_STEWARD_CMD='claude "…your standing orders…"; exec $SHELL'

# Handoff destination (/fleet-handoff, commands/fleet-handoff.md, issue #275).
# Where the handoff doc is STORED so a cleared session can resume from it:
#   comment  (default) — when the pane is issue-bound (a worker's @issue, or a
#            steward's FLEET_STEWARD_ISSUE), post the doc as a durable
#            `<!-- fleet:handoff -->`-marked issue COMMENT. It outlives the
#            worktree teardown a committed doc/handoff/*.md does not, and pickup
#            self-resolves it from the pane's @issue (no path to remember). A raw
#            scratch / no-issue pane still falls back to a local file.
#   file     — force the local-file convention for EVERY pane (no comment ever).
#            Use on a SENSITIVE repo where even a scrubbed handoff must not be
#            pushed to a public issue thread.
# Empty is treated as the default (comment).
# @label=Handoff destination (comment|file) @group=steward @tier=advanced @scope=fleet @edit=enum
#FLEET_HANDOFF_DEST=comment

# Multiple subscription accounts, with auto-failover when one hits its usage
# limit (the rolling 5-hour "session" window or the weekly cap). Register each
# account as a token FILE — name = label, contents = its OAuth token from
# `claude setup-token` (chmod 600) — in this directory. When the collector sees
# a session print "You've hit your … limit", it marks that account and rotates,
# so NEW sessions launch on a fresh subscription. Empty/absent dir → OFF (the
# fleet uses your single logged-in account exactly as before). See
# docs/MULTI-ACCOUNT.md.
# @label=Account tokens dir @group=identity @tier=advanced @scope=identity @edit=no
#FLEET_ACCOUNTS_DIR="$HOME/.config/claude-fleet/accounts"
# Optional: pin the account order/subset (space-separated labels); default is
# every token file, sorted by name.
# @label=Subscription accounts @group=accounts @tier=advanced @scope=global @edit=str
#FLEET_ACCOUNTS="work personal spare"
# How long a limited account stays out of rotation before it's eligible again
# (seconds; default 18000 = the 5-hour session window).
# @label=Account limit re-check @group=accounts @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_ACCOUNT_LIMIT_TTL=18000

# Detached-attention escalation: when a session is blocked on your input for
# FLEET_ESCALATE_AFTER seconds and NO tmux client is attached, the collector
# runs FLEET_NOTIFY_CMD with the message as $1. Plug in any notifier:
# A ready-made WeCom 群机器人 notifier ships in extras/ (put the webhook URL in
# ~/.config/claude-fleet-webhook, chmod 600):
# GLOBAL: the two readers — the collector (bin/tmux-dash-collect.sh) and the
# disk guard (bin/fleet-diskguard.sh) — are single machine-wide daemons that read
# this from the global env; a per-fleet override never reaches them (silent no-op),
# so it is machine-wide like its companion FLEET_ESCALATE_AFTER.
# @label=Notification command @group=notify @tier=common @scope=global @edit=path
#FLEET_NOTIFY_CMD="$HOME/.claude/fleet/extras/wecom-webhook-notify.sh"
# @label=Escalate unattended after @group=notify @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_ESCALATE_AFTER=300

# Disk-pressure guard (bin/fleet-diskguard.sh). The tmux server is shared by
# every fleet, so a full volume ENOSPCs the collector and kills the server —
# taking ALL fleets down at once. The guard measures the volume backing $TMPDIR
# (where the dash cache lives) and:
#   • GATE — fleet-up (spawn) and fleet-restore --if-down (auto-restore) refuse
#     to add load when free < FLEET_DISK_FLOOR_GB, so auto-restore can't rebuild
#     fleets straight back into a full disk (the restore⇄crash loop).
#   • WATCH — the com.claude-fleet.diskguard daemon (60s) captures a forensic
#     incident (open-but-deleted fds, largest recent files, top RSS) under
#     ~/.config/claude-fleet/diskguard/ and fires FLEET_NOTIFY_CMD when free
#     drops below FLEET_DISK_WARN_GB. Defaults shown:
# @label=Stop spawning below disk GB @group=disk @tier=advanced @scope=global @edit=int @unit=GB
#FLEET_DISK_FLOOR_GB=12       # gate refusal threshold
# @label=Disk warning GB @group=disk @tier=advanced @scope=global @edit=int @unit=GB
#FLEET_DISK_WARN_GB=15        # watch capture + notify threshold
# (The volume the guard measures and the min seconds between incident captures are
# fixed internal constants now — the guard MUST measure the $TMPDIR volume the dash
# cache writes to, and the capture cooldown is plumbing no one tunes. A stale
# FLEET_DISK_TARGET / FLEET_DISK_COOLDOWN in an old conf is still honored by
# bin/fleet-diskguard.sh but is no longer a surfaced knob — issue #237.)

# Runaway-CPU watchdog (same daemon). The shared tmux server can also be
# overloaded by a detached orphan spinning a core (issue #151, crash #3: a
# since-fixed hang from an already-removed worktree pegged 100% for ~1h). The
# --watch tick flags OUR-USER processes at/above FLEET_RUNAWAY_CPU_PCT % CPU held
# for >= FLEET_RUNAWAY_CPU_SECS with NO controlling terminal (a reparented orphan;
# live worker panes have a pts and are never touched — the tmux server + launchd/
# systemd are excluded outright). It then captures a forensic incident under
# ~/.config/claude-fleet/diskguard/ and fires FLEET_NOTIFY_CMD; with ACTION=kill it
# also SIGTERM→SIGKILLs the runaway. OFF by default — set PCT>0 to enable.
# @label=Runaway CPU percent @group=disk @tier=advanced @scope=global @edit=int @unit=%
#FLEET_RUNAWAY_CPU_PCT=0        # %CPU that counts as hot; 0 = watchdog OFF
# @label=Runaway CPU seconds @group=disk @tier=advanced @scope=global @edit=int @unit=sec
#FLEET_RUNAWAY_CPU_SECS=300     # seconds sustained-hot before it's a runaway
# @label=Runaway CPU action @group=disk @tier=advanced @scope=global @edit=str
#FLEET_RUNAWAY_CPU_ACTION=notify  # notify (forensics+notify only) | kill (also SIGTERM/KILL)

# --- Spawn ergonomics -------------------------------------------------------
# By default a newly spawned worker window is created in the background (tmux
# new-window -d) and NOT selected — you stay on your current window, and the new
# session surfaces via the dash + urgency sorter. Set to 1 to restore the old
# behavior: interactive spawns (backlog Enter / new-session box) jump to the new
# window. Headless spawns never steal focus regardless.
# @label=Jump to new worker windows @group=spawn @tier=common @scope=fleet @edit=bool
#FLEET_SPAWN_FOCUS=0

# --- Cross-machine pre-spawn dedup (bin/dash-issue-session.sh, issue #258) --------
# ON by default (set to 0 to opt out). The local spawn dedup only sees THIS machine's
# tmux server. When two fleets run on DIFFERENT machines against the SAME repo, a
# peer's worker is invisible, so both can spawn issue-<N> — duplicate worktrees, a
# non-fast-forward push race, and competing PRs. With this on, every spawn first
# consults the shared GitHub issue as the claim ledger (assignee · state · a ▶
# claiming comment · an open PR); if the issue is already claimed it refuses. If free
# it claims AT SPAWN (assignee + marker) — not on the worker's first /fleet-claim
# turn, which was the race — then a best-effort tie-break (earliest ▶ claiming
# comment wins) rolls back and refuses if a peer claimed in the same sub-second overlap.
#
# NOT a mutex: GitHub has no compare-and-swap on an issue, so this SHRINKS the
# duplicate-spawn window to a sub-second race, it does not eliminate it. COST: a few
# gh READS per spawn (latency + a little rate limit) — claim-at-spawn only moves the
# worker's own /fleet-claim writes earlier (same write count; /fleet-claim then
# no-ops), and a gh outage/absence degrades to spawn-anyway, never a false refusal. A
# single-machine fleet that wants the zero-gh fast path can set this to 0. Same-account
# caveat: all workers assign the SAME gh account, so a HUMAN self-assigning an issue
# they aren't fleet-working reads as taken and is skipped (arguably correct). Stale
# claim from a dead worker? Spawn past it with `dash-issue-session.sh <N> --force`
# (alias --reclaim).
# @label=Cross-machine pre-spawn dedup @group=spawn @tier=common @scope=fleet @edit=bool
#FLEET_PRESPAWN_DEDUP=1

# --- Auto-merge strategy (issue #283) ---------------------------------------
# The GitHub auto-merge strategy the fleet ARMS. THE FLEET NEVER MERGES — the
# worker's /fleet-claim ship step (and the dash ⌃l arm) run
# `gh pr merge --auto --<method>`; GitHub performs the merge when the PR is green.
# squash (default) | merge | rebase. An unset/typo'd value falls back to squash so
# arming never breaks on a bad key. Per-fleet ▸ global ▸ default.
# @label=Auto-merge method @group=spawn @tier=common @scope=fleet @edit=enum
#FLEET_MERGE_METHOD="squash"

# --- Repo worker charter (issue #283) ---------------------------------------
# When 1, /fleet-claim loads a repo-shipped worker charter from
# $FLEET_MAIN/.fleet/worker.md and layers it under the fleet overlay (operator)
# charter. OFF by default (fail-closed): .fleet/worker.md is an INJECTION SURFACE
# — PRs auto-merge on green CI with no human review, so a PR could rewrite the
# charter every future worker then obeys. Opt in ONLY on a repo where you trust
# what lands, and on a public repo protect .fleet/ with CODEOWNERS + required
# review. The fleet overlay charter (~/.config/.../fleets/<session>/worker.md)
# needs no gate — only the operator writes it.
# @label=Load repo worker charter @group=spawn @tier=advanced @scope=fleet @edit=bool
#FLEET_REPO_CHARTER=0

# --- Worker seed prompt (issue #234) ----------------------------------------
# The operator-facing BODY of the one-shot prompt a newly spawned IMPLEMENTING
# worker is seeded with. Since issue #283 the seed COLLAPSES to essentially "run
# /fleet-claim" (the skill carries the whole lifecycle: claim → charter → ground →
# implement → open PR + arm auto-merge). The full seed is STRUCTURAL + body:
#   Work GitHub issue #<n> in this repo. <run /fleet-claim …> <BODY><ship+stop tail>
# Only <BODY> is customizable — the issue-binding head, the /fleet-claim ritual,
# and the "open the PR + arm auto-merge, then STOP" tail are kept intact so the
# fleet machinery still works. (For richer per-fleet standing orders, prefer the
# fleet overlay worker charter — see FLEET_REPO_CHARTER above.) Unset ⇒ the
# built-in default below. Placeholders {issue} and {repo} are substituted; a
# trailing sentence-ender is stripped so the body flows into the tail. Per-fleet ▸
# global ▸ default like any @scope=fleet key.
# @label=Worker seed prompt @group=spawn @tier=common @scope=fleet @edit=str
#FLEET_WORKER_PROMPT="Implement and verify per the repo conventions"

# A FILE whose contents are the worker seed BODY (above) — use this instead of
# FLEET_WORKER_PROMPT for a long or multi-line template the single-line modal
# editor can't hold. A leading ~/ is expanded. Takes precedence over
# FLEET_WORKER_PROMPT when set and readable; if the path is set but unreadable the
# spawn warns and falls back to the inline value / default. Same {issue}/{repo}
# placeholders.
# @label=Worker seed prompt file @group=spawn @tier=advanced @scope=fleet @edit=path
#FLEET_WORKER_PROMPT_FILE="$HOME/.config/claude-fleet/worker-prompt.txt"
