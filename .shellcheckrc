# claude-fleet — shellcheck baseline
#
# Per-file shells come from each script's shebang (mix of #!/bin/sh and
# #!/bin/bash), so we don't force `shell=` here — that keeps the POSIX checks
# on the /bin/sh scripts.
#
# Agreed disables: the fleet scripts source runtime config and sibling libs by
# path (`. "$BIN/../fleet.conf"`, `. "$BIN/fleet-lib.sh"`, and dynamic
# `$FLEET_STEWARD_CMD`-style paths). shellcheck can't resolve those at lint
# time, so it emits SC1090/SC1091 for every one. They're expected, not bugs —
# silence them globally and keep the rest of the tree clean.
disable=SC1090,SC1091
