{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/set-claude-state.sh busy" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ~/.claude/fleet/hooks/bash-guard.py" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python3 ~/.claude/fleet/hooks/base-readonly-guard.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/set-claude-state.sh working" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/set-claude-state.sh working" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/set-claude-state.sh needs bell" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/set-claude-state.sh done" },
          { "type": "command", "command": "sh ~/.claude/fleet/bin/summarize-hook.sh" },
          { "type": "command", "command": "sh ~/.claude/fleet/bin/classify-hook.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "sh ~/.claude/fleet/bin/summarize-hook.sh" },
          { "type": "command", "command": "sh ~/.claude/fleet/bin/steward-readopt-hook.sh" },
          { "type": "command", "command": "sh ~/.claude/fleet/bin/handoff-latch-reset-hook.sh" }
        ]
      }
    ]
  }
}
